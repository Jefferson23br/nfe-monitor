# Banco de dados PostgreSQL
DB_HOST=localhost
DB_NAME=nfe_monitor
DB_USER=postgres
DB_PASS=

# Chave para criptografar senhas dos certificados (mín. 32 caracteres aleatórios)
NFE_APP_KEY=

# E-mail: remetente e modo dev (1 = exibe link na tela se mail() falhar)
NFE_MAIL_FROM=noreply@suaempresa.com.br
NFE_DEV_MODE=0

# Certificado digital (alternativa ao campo pfx_password em config.local.php)
NFE_PFX_PASSWORD=

# Deploy (scripts PowerShell)
NFE_DEPLOY_SSH=root@seu-servidor
